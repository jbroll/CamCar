# Copy to .env (untracked) and fill in your network. `make build` bakes these
# into src/gen/secrets.h, which seeds NVS on first boot. Leave blank/absent to
# boot straight into SoftAP setup mode instead.
WIFI_SSID=
WIFI_PASSWORD=

# Web/OTA password baked in at flash time (gates firmware updates and settings
# changes). Defaults to "camcar" if blank/absent. Change it on the device later
# via the hamburger dialog's Device Password field.
DEVICE_PASSWORD=
